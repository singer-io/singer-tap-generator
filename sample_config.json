{
  "tap_name": "Harvest",
  "required_config_keys": ["refresh_token", "client_id", "client_secret", "start_date", "user_agent"],
  "page_size": 100,
  "next_page_key": "next_page",
  "pagination_key": "page",
  "headers": {"Accept": "application/json"},
  "params": {},
  "auth_header_key": "Authorization",
  "auth_config_key": "access_token",
  "base_url": "https://api.harvestapp.com/v2/",
  "streams": [
    {
      "name": "projects",
      "key_properties": ["id"],
      "replication_method": "FULL_TABLE",
      "path": "projects",
      "data_key": "projects",
      "doc_link": "https://help.getharvest.com/api-v2/projects-api/projects/projects/"
    },
    {
      "name": "clients",
      "key_properties": ["id"],
      "replication_method": "INCREMENTAL",
      "replication_keys": ["updated_at"],
      "path": "clients",
      "data_key": "clients",
      "doc_link": "https://help.getharvest.com/api-v2/clients-api/clients/clients/"
    },
    {
      "name": "expenses",
      "key_properties": ["id"],
      "replication_method": "INCREMENTAL",
      "replication_keys": ["updated_at"],
      "path": "expenses",
      "data_key": "expenses",
      "doc_link": "https://help.getharvest.com/api-v2/expenses-api/expenses/expenses/"
    },
    {
      "name": "invoice_line_items",
      "key_properties": ["id"],
      "replication_method": "INCREMENTAL",
      "replication_keys": ["updated_at"],
      "path": "invoice_line_items",
      "data_key": "invoice_line_items",
      "parent": "invoices",
      "doc_link": "https://help.getharvest.com/api-v2/invoices-api/invoices/invoices#the-invoice-line-item-object"
    },
    {
      "name": "invoice_payments",
      "key_properties": ["id"],
      "replication_method": "INCREMENTAL",
      "replication_keys": ["updated_at"],
      "path": "invoices/{}/payments",
      "data_key": "invoice_payments",
      "parent": "invoices",
      "doc_link": "https://help.getharvest.com/api-v2/invoices-api/invoices/invoice-payments/"
    },
    {
      "name": "invoices",
      "key_properties": ["id"],
      "replication_method": "INCREMENTAL",
      "replication_keys": ["updated_at"],
      "path": "invoices",
      "data_key": "invoices",
      "children": ["invoice_payments", "invoice_messages", "invoice_line_items"],
      "doc_link": "https://help.getharvest.com/api-v2/invoices-api/invoices/invoices/"
    }
  ],
  "tap_tester_creds": {
    "client_id": "TAP_HARVEST_CLIENT_ID",
    "client_secret": "TAP_HARVEST_CLIENT_SECRET",
    "refresh_token": "TAP_HARVEST_REFRESH_TOKEN"
  },
  "author": "Stitch",
  "third_party_dependencies": [
      "singer-python==5.12.1",
      "requests==2.31.0"
  ]
}
